# === Matrix ===
MATRIX_HOMESERVER=https://your-matrix-server.example.com
MATRIX_ACCESS_TOKEN=your_access_token_here
MATRIX_USER_ID=@username:your-matrix-server.example.com
MATRIX_DEVICE_ID=redmine_bot

# === Redmine ===
REDMINE_URL=https://your-redmine.example.com
REDMINE_API_KEY=your_api_key_here

# === Timezone ===
BOT_TIMEZONE=Europe/Moscow

# === PostgreSQL ===
POSTGRES_USER=bot
POSTGRES_PASSWORD=change-me
POSTGRES_PASSWORD_URLENC=change-me
POSTGRES_DB=redmine_matrix
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === Admin UI (email allow-list) ===
ADMIN_EMAILS=dmitry@example.com
ADMIN_BOOTSTRAP_FIRST_ADMIN=0
ADMIN_PORT=8080

# === Auth for admin/session tokens ===
AUTH_TOKEN_SALT=dev-change-me-in-prod
MAGIC_TOKEN_TTL_SECONDS=900
SESSION_TTL_SECONDS=86400

# === Matrix binding (one-time code) ===
MATRIX_CODE_TTL_SECONDS=300

