# Matrix-сервер
MATRIX_HOMESERVER=https://your-matrix-server.example.com
MATRIX_ACCESS_TOKEN=your_access_token_here
MATRIX_USER_ID=@username:your-matrix-server.example.com
MATRIX_DEVICE_ID=redmine_bot

# Matrix-комнаты
MATRIX_ROOM_ID=!your_room_id:your-matrix-server.example.com
MATRIX_TEAM_ROOM_ID=
STATUS_ROOM_MAP={}

# Redmine
REDMINE_URL=https://your-redmine.example.com
REDMINE_API_KEY=your_api_key_here

# Таймзона
BOT_TIMEZONE=Europe/Moscow

# Интервал опроса Redmine (секунды), по умолчанию 90; минимум 15
# CHECK_INTERVAL=120

# Логи (опционально)
# LOG_TO_FILE=1          # 0|false|no|off — только stdout (удобно, если достаточно docker logs)
# LOG_PATH=              # не задано — data/bot.log; иначе путь от корня проекта или абсолютный

# PostgreSQL (docker-compose: сервис postgres; DATABASE_URL подставляется в bot и admin)
# POSTGRES_USER=bot
# POSTGRES_PASSWORD=сгенерируйте_надёжный_пароль
# POSTGRES_DB=redmine_matrix

# Конфиг из БД: 1 — USERS / маршруты читать из Postgres (заполнение через сервис admin)
# USE_DB_CONFIG=0

# Веб-админка (сервис admin): токен для входа в UI; не коммитить в репозиторий
# ADMIN_TOKEN=длинная_случайная_строка
# ADMIN_PORT=8080
