<h3>Обзор уведомлений</h3>
<p>За время вашего отсутствия:</p>
{% set digest_list = digest_items if digest_items is defined else items %}
{% for item in digest_list %}
<hr />
<p><strong>#{{ item.issue_id | default('') }} — {{ item.subject | default('') }}</strong></p>
{% if item.events is defined and item.events %}
<p>События: {{ item.events | join(', ') }}</p>
{% endif %}
{% if item.status_name | default('') or item.assigned_to | default('') %}
<p>
{% if item.status_name | default('') %}Статус: {{ item.status_name }}{% endif %}
{% if item.assigned_to | default('') %}{% if item.status_name | default('') %} · {% endif %}Исполнитель: {{ item.assigned_to }}{% endif %}
</p>
{% endif %}
{% if item.changes is defined and item.changes %}
<ul>
{% for c in item.changes %}
  <li>{{ c.field | default('Поле') }}: {{ c.old | default('—') }} → {{ c.new | default('—') }}</li>
{% endfor %}
</ul>
{% endif %}
{% if item.comments is defined and item.comments %}
{% for c in item.comments %}
<p>💬 {{ c }}</p>
{% endfor %}
{% endif %}
{% if item.reminders_count | default(0) > 0 %}
<p>⏰ Напоминаний: {{ item.reminders_count }}</p>
{% endif %}
{% if item.url | default('') %}
<p><a href="{{ item.url }}">Открыть задачу</a></p>
{% endif %}
{% endfor %}
<p>Всего задач: {{ digest_list | length }}</p>
