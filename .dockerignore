# =============================================================================
# Исключения из контекста сборки `docker build` (меньше контекст → быстрее build).
# Секреты и мусор в образ не попадают.
# =============================================================================

# Git и IDE
.git
.gitignore
.cursor
.idea
.vscode
*.swp

# Локальное окружение Python (образ ставит зависимости сам)
venv
.venv
__pycache__
*.py[cod]
*$py.class
.pytest_cache
.mypy_cache
.ruff_cache

# Секреты и локальные данные — монтируются томами при runtime, не копируются в слой образа
.env
.env.*
!.env.example

# State и логи с хоста не должны попасть в immutable-слой (и раздувают контекст)
data/*.log
*.log
bot.log*

# Тесты не нужны для production-образа
tests

# Документация не нужна внутри контейнера для работы бота
*.md
docs

# Compose-override на хосте (опционально)
docker-compose.override.yml
